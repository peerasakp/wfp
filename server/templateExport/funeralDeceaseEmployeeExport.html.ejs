<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ใบเบิกสวัสดิการค่าสงเคราะห์การเสียชีวิตของผู้ปฎิบัติงานในมหาวิทยาลัย
      ประจำปี</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Bai+Jamjuree:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet">
    <%- cssStyles %>
  </head>

  <body>
    <% const toThaiNumber=(num)=> {
    return String(num).replace(/\d/g, d => "๐๑๒๓๔๕๖๗๘๙"[d]);
    };
    %>
    <div class="content">
      <div class="d-flex justify-end font-14"><span class="font-semi-bold">แบบ
          สก.๐๔</span></div>
      <div class="d-flex justify-center font-20 pt-md">
        <span
          class="font-semi-bold">ใบเบิกสวัสดิการค่าสงเคราะห์การเสียชีวิตของผู้ปฎิบัติงานในมหาวิทยาลัย
        </span>
      </div>
      <div class="d-flex justify-center font-20 ">
        <span class="font-semi-bold">กองทุนสวัสดิการมหาวิทยาลัยบูรพา</span>
      </div>

      <div class="d-flex justify-center font-14 pt-sm pb-md">
        โปรดทำเครื่องหมาย / ลงในช่อง
        <input type="checkbox" id="fake" name="fake" value="fake" />
        พร้อมทั้งกรอกรายละเอียดให้ครบถ้วน
      </div>
      <table>
        <tr>
          <td>
            <div class="d-flex">
              <div style="width: 100%">
                <div class="row" style="gap: 8px; flex-wrap: wrap">
                  <div class="pl-sm font-semi-bold">๑.</div>
                  <div style="flex: 1;" class="d-flex">
                    <span class="font-semi-bold">๑.ข้าพเจ้า :</span>
                    <span class="text-dot pl-sm text-center">
                      <%= body?.user?.name %></span>
                  </div>
                  <span
                    class="font-semi-bold pr-xl">(เจ้าหน้าที่ผู้รับผิดชอบด้านบุคคล)</span>
                </div>
                <div class=" row pt-sm pb-sm"
                  style="gap: 8px; flex-wrap: wrap;">
                  <div style="flex: 1; padding-left: 20px;" class="d-flex">
                    <span class="pl-sm font-semi-bold">ตำแหน่ง :</span>
                    <span class="text-dot pl-sm text-center">
                      <%= body?.user?.position %></span>
                  </div>
                  <div class="pr-xl">
                    <span class="font-semi-bold">สังกัด ภาควิชา / ส่วนงาน
                      :</span>
                    <span class="text-dot pl-sm text-center">
                      <%= body?.user?.sector %> / <%= body?.user?.department
                      %></span>
                  </div>
                </div>
              </div>
            </div>
          </td>
        </tr>
        <!-- ส่วนงานขอเบิกสวัสดิการค่าสงเคราห์การเสียชีวิตของผู้ปฎิบัติงานในมหาวิทยาลัย -->
        <tr>
          <td>
            <div class="row" style="gap: 8px">
              <div style="width: 100%">
                <div class="d-flex">
                  <div class=" px-sm  font-semi-bold">
                    ๒.
                  </div>
                  <span
                    class="font-semi-bold">ส่วนงานขอเบิกสวัสดิการค่าสงเคราห์การเสียชีวิตของผู้ปฎิบัติงานในมหาวิทยาลัย
                    <span style="font-size: 12px;">(ให้จ่ายจริงคนละไม่เกิน
                      ๑๐,๐๐๐ บาท )</span></span>
                </div>
                <div class="d-flex">
                  <div style="width: 5%;"></div>
                  <div style="width: 95%;">
                    <div class="row pt-md px-md" style="gap: 8px">
                      <div style="flex: 1" class="d-flex px-sm font-semi-bold">
                        <label>ชื่อ-นามสกุล (ผู้ปฏิบัติงานเสียชีวิต)</label>
                        <span style="max-width: 250px; width: 250px;"
                          class="<%= body?.deceased?.name ?  'text-dot text-center' : 'text-dot-no-value' %>">
                          <%= body?.deceased?.name ? body.deceased.name
                          :
                          ""
                          %></span>
                        <label>ตำแหน่ง</label><span
                          style="max-width: 195px; width: 195px;"
                          class="<%= body?.deceased?.position?.name ?  'text-dot text-center' : 'text-dot-no-value' %>">
                          <%= body?.deceased?.position?.name ?
                          body.deceased.position?.name
                          :
                          ""
                          %></span>

                      </div>
                    </div>
                    <div class="row pt-sm px-md" style="gap: 8px">
                      <div style="flex: 1" class="d-flex px-sm font-semi-bold">
                        <label>สังกัด ภาควิชา/ส่วนงาน</label>
                        <span style="max-width: 550px; width: 550px;"
                          class="<%= (body?.deceased?.sector?.name || body?.deceased?.department?.name) ? 'text-dot text-center' : 'text-dot-no-value' %>">
                          <%= (body?.deceased?.sector?.name ||
                          body?.deceased?.department?.name)
                          ? (body.deceased.sector?.name ?
                          body.deceased.sector.name + "/" : "") +
                          (body.deceased.department?.name ?
                          body.deceased.department.name : "")
                          :
                          ""
                          %>
                        </span>

                      </div>
                    </div>
                    <div class="row pt-sm px-md " style="gap: 8px">
                      <div style="flex: 1" class="d-flex px-sm font-semi-bold ">
                        <label>โดยค่าสงเคราะห์การเสียชีวิตของผู้ปฎิบัติงานให้จ่ายให้กับผู้จัดการงานศพชื่อ-นามสกุล</label>
                        <span style="max-width: 200px; width: 200px;"
                          class="<%= body?.organizer ?  'text-dot text-center' : 'text-dot-no-value' %>">
                          <%= body?.organizer ? body.organizer
                          :
                          ""
                          %></span>

                      </div>
                    </div>
                    <div class="row pl-md py-sm" style="gap: 8px">
                      <div style="flex: 1" class="pส-sm">
                        <span style="padding-left: 32px;"></span><span
                          class="font-semi-bold">หลักฐานแนบ</span>
                      </div>
                    </div>
                    <div class="row" style="gap: 8px; padding-left: 32px">
                      <div style="flex: 1" class="pl-md d-flex">
                        <div>๑.สำเนาใบมรณะบัตรผู้ปฎิบัติงาน</div>
                        <div
                          class="px-xl">๒.สำเนาบัตรประชาชนผู้จัดการงานศพ</div>
                      </div>
                    </div>
                    <div class="row" style="gap: 8px; padding-left: 32px">
                      <div style="flex: 1" class="pl-md d-flex">
                        <div>๓.ใบสำคัญรับเงินโดยผู้จัดการงานศพพร้อมคำรับรองการเป็นผู้จัดการงานศพ</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </td>
        </tr>
        <!-- คำรับรองการเป็นผู้จัดการงานศพ -->
        <tr>
          <td>
            <div class="row" style="gap: 10px">
              <div style="width: 100%">
                <div class="d-flex">
                  <span
                    class="font-semi-bold pr-sm px-sm  ">คำรับรองการเป็นผู้จัดการงานศพ</span>
                </div>
                <div class="d-flex">
                  <div style="width: 5%;"></div>
                  <div style="width: 95%;">
                    <div class="row pl-md py-sm" style="gap: 8px">
                      <div class="py-sm">
                        <div style="flex: 1" class="pl-sm d-flex">
                          <span
                            style="padding-left: 24px;"></span><span>ข้าพเจ้าขอรับรองว่า</span>
                          <span style="max-width: 110px; width: 110px;"
                            class="<%= body?.organizer ? 'text-dot text-center' : 'text-dot-no-value' %>">
                            <%= body?.organizer ? body.organizer : "" %>
                          </span>

                          <span>(ชื่อ-นามสกุล ผู้จัดการงานศพ)
                            ได้เป็นผู้จัดการการงานศพและรับเงินค่าสงเคราะห์</span>
                        </div>

                        <div style="flex: 1" class="d-flex pt-sm">
                          <span class="pl-sm ">การเสียชีวิตของผู้ปฎิบัติงาน
                            จำนวนเงิน</span> <span
                            style="max-width: 100px; width: 100px;"
                            class="<%=  body?.fundRequest ? 'text-dot text-center' : 'text-dot-no-value' %>">

                            <%= body?.fundRequest ?
                            toThaiNumber(Number(body?.fundRequest).toLocaleString('en-US',{
                            minimumFractionDigits:
                            body?.fundRequest % 1===0 ? 0 : 2,
                            maximumFractionDigits: 2, }))
                            : '' %>
                          </span> <span>บาท</span>
                          (<span style="max-width: 220px; width: 220px;"
                            class="<%=  body?.fundRequest ?  'text-dot text-center' : 'text-dot-no-value' %>">
                            <%= body?.fundRequest ?
                            bahttext(Number(body?.fundRequest))
                            :
                            ""
                            %>
                          </span>) <span>จริง</span>
                        </div>

                      </div>
                    </div>
                    <div class="justify-center py-md px-xl pr-xl">
                      <div class="row">
                        <div class="col-12 d-flex justify-end"
                          style="padding-right: 80px;">
                          ลงชื่อ<span class="text-dot-no-value"
                            style="max-width: 170px;"></span>ผู้ขอรับเงิน
                          (เจ้าหน้าที่ผู้รับผิดชอบด้านบุคคล)
                        </div>
                        <div class="col-12 py-sm pl-sm d-flex justify-center">
                          (<span class="text-dot-no-value"
                            style="max-width: 170px;"></span>)
                        </div>
                        <div class="col-12 py-sm  d-flex justify-center">
                          วันที่<div class="text-dot-no-value"
                            style="max-width: 30px;"> </div>เดือน <div
                            class="text-dot-no-value" style="max-width: 50px;">
                          </div> พ.ศ. <div class="text-dot-no-value"
                            style="max-width: 30px;">
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </td>
          </tr>
          <!-- สวัสดิการสนับสนุนค่าพวงหลีด -->
          <tr>
            <td>
              <div class="row" style="gap: 10px">
                <div style="width: 100%">
                  <div class="d-flex">
                    <div class=" px-sm  font-semi-bold">
                      ๓.
                    </div>
                    <span
                      class="font-semi-bold">ส่วนงานขอเบิกค่าค่าสนับสนุนค่าพวงหลีด
                      <span
                        style="font-size: 12px;">(ในนามมหาวิทยาลัยบูรพาไม่เกิน
                        ๒,๐๐๐ บาท ในนามส่วนงานไม่เกิน ๒,๐๐๐ บาท)</span>
                    </span>
                  </div>
                  <div class="d-flex">
                    <div style="width: 5%;"></div>
                    <div style="width: 100%;">
                      <div class="row pl-md py-sm" style="gap: 8px">
                        <div style="flex: 1" class="pส-sm">
                          <span style="padding-left: 32px;"></span><span
                            class="font-semi-bold">หลักฐานแนบ</span>
                        </div>
                      </div>
                      <div class="row" style="gap: 8px; padding-left: 32px">
                        <div style="flex: 1" class="pl-md d-flex">
                          <div>๑.สำเนาใบมรณะบัตรผู้ปฎิบัติงาน</div>
                          <div class="px-xl">๒.ใบสำคัญรับเงิน
                            (โดยเจ้าหน้าที่ผู้รับผิดชอบด้านบุคคล
                            ลงนามรับเงิน)</div>
                        </div>
                      </div>
                      <div class="row" style="gap: 8px; padding-left: 32px">
                        <div style="flex: 1" class="pl-md d-flex">
                          <div>๓.ใบเสร็จรับเงิน</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </td>
          </tr>
          <!-- สวัสดิการสนับสนุนค่าพาหนะ -->
          <tr>
            <td>
              <div class="row" style="gap: 10px">
                <div style="width: 100%">
                  <div class="d-flex">
                    <div class=" px-sm  font-semi-bold">
                      ๔.
                    </div>
                    <span class="font-semi-bold">ค่าสนับสนุนค่าพาหนะเหมาจ่าย
                      เพื่อไปร่วมงานสมรส งานอุปสมบท งานศพของผู้ปฎิบัติงาน <span
                        style="font-size: 12px;">(เท่าที่จ่ายจริง งานละไม่เกิน
                        ๒๐,๐๐๐ บาท)</span>
                    </span>
                  </div>
                  <div class="d-flex">
                    <div style="width: 5%;"></div>
                    <div style="width: 100%;">
                      <div class="row pl-md py-sm" style="gap: 8px">
                        <div style="flex: 1" class="pส-sm">
                          <span style="padding-left: 32px;"></span><span
                            class="font-semi-bold">หลักฐานแนบ</span>
                        </div>
                      </div>
                      <div class="row" style="gap: 8px; padding-left: 32px">
                        <div style="flex: 1" class="pl-md d-flex">
                          <div class="font-14 ">๑.ใบสำคัญรับเงิน
                            (โดยเจ้าหน้าที่ผู้รับผิดชอบด้านบุคคล<br>
                            ลงนามรับเงิน)</div>
                          <div class="px-xl font-14">๒.ใบเสร็จรับเงิน หรือ
                            หลักฐานการจ่ายเงินอื่น</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </td>
          </tr>
          <tr>
            <td>
              <div class="row" style="gap: 8px">
                <span class="font-semi-bold px-md"
                  class="col-12 px-md">การตรวจสอบ</span>
                <div class="col-12 px-md d-flex">
                  <span class="font-semi-bold px-md">เสนอ</span>
                  <span style="max-width: 100px; width: 100px;"
                    class="text-dot text-center">
                    <%= body?.user?.positionId==2 || body?.user?.positionId==3 ?
                    "อธิการบดี" : "คณบดี" %>
                  </span>
                </div>
              </div>
              <div class="d-flex">
                <div style="width: 5%;"></div>
                <div class="row px-md py-sm" style="gap: 8px; width: 95%;">
                  <div class="col-12">
                    ๑. ข้าพเจ้า ได้ตรวจสอบใบขอเบิกเงินสวัสดิการฉบับนี้แล้ว
                    ขอรับรองว่าผู้ขอเบิกสวัสดิการฯ มีสิทธิเบิกสวัสดิการฯ
                    ได้ตามประกาศ คณะกรรมการสวัสดิการ มหาวิทยาลัยบูรพา
                  </div>
                  <div class="col-12 pl-sm ml-sm row">
                    ๒. ผู้ขอรับสวัสดิการฯ
                    มีสิทธิเบิกตามจำนวนเงินที่ขอเบิก <div
                      class="text-dot-no-value"
                      style="max-width: 100px !important; width: 100px !important;"></div>
                    บาท
                    จริง ไม่เกินอัตราที่กำหนดต่อปี
                  </div>
                </div>
              </div>
              <div class="row px-md py-sm"
                style="gap: 8px; align-items: flex-end">
                <div class="col"></div>
                <div class="col row justify-center">
                  <div class="col-sign">
                    ลงชื่อ <div class="text-dot-no-value"
                      style="max-width: 200px;"></div>ผู้ตรวจสอบ
                  </div>
                  <div class="col-sign py-sm">
                    ( <div class="text-dot" style="max-width: 220px;"> </div> )
                  </div>
                  <div class="col-position px-md">
                    ตำแหน่ง <div class="text-dot text-center" style="width: 230px;"> นักวิชาการเงินและบัญชีชำนาญการ</div>
                  </div>
                  <div class="col-sign py-sm">
                    วันที่<div class="text-dot-no-value"
                      style="max-width: 50px;"> </div>เดือน <div
                      class="text-dot-no-value" style="max-width: 50px;"> </div>
                    พ.ศ. <div class="text-dot-no-value"
                      style="max-width: 50px;"> </div>
                  </div>
                </div>
              </div>
            </td>
          </tr>
        </table>
      </div>
      <!-- New Page -->
      <div class="page-break"></div>
      <div class="py-sm"></div>
      <div class="content">
        <table>
          <tr>
            <td>
              <div class="row" style="gap: 8px">
                <span class="font-semi-bold px-md"
                  class="col-12 px-md">คำอนุมัติ</span>
              </div>
              <div class="d-flex py-sm" style="width: 100%;">
                <div style="width: 5%;"></div>
                <div style="width: 95%;" class="pl-md ml-md">
                  <div class="pl-md ml-md"> อนุมัติเบิกจ่ายได้</div>
                </div>
              </div>
              <div class="row px-md py-sm"
                style="gap: 8px; align-items: flex-end">
                <div class="col"></div>
                <div class="col row justify-center">
                  <div class="col-sign">
                    ลงชื่อ <div class="text-dot-no-value"
                      style="max-width: 200px;"></div>ผู้อนุมัติ
                  </div>
                  <div class="col-sign py-sm">
                    ( <div class="text-dot" style="max-width: 220px;"> </div> )
                  </div>
                  <div class="col-sign px-md">
                    ตำแหน่ง <div class="text-dot-no-value"
                      style="max-width: 170px;"></div>
                  </div>
                  <div class="col-sign py-sm">
                    วันที่<div class="text-dot-no-value"
                      style="max-width: 50px;"> </div>เดือน <div
                      class="text-dot-no-value" style="max-width: 50px;"> </div>
                    พ.ศ. <div class="text-dot-no-value"
                      style="max-width: 50px;"> </div>
                  </div>
                </div>
              </div>
            </td>
          </tr>
          <tr>
            <td>
              <div class="row" style="gap: 8px">
                <span class="font-semi-bold px-md"
                  class="col-12 px-md">ใบรับเงิน</span>
              </div>
              <div class="d-flex pb-sm" style="width: 100%;">
                <div style="width: 5%;"></div>
                <div style="width: 95%;">
                  <div class="row px-md ml-md pt-md" style="gap: 8px">
                    <div class="col-12 pl-md ml-md">
                      ข้าพเจ้าได้รับเงินสวัสดิการตามประกาศคณะกรรมการสวัสดิการ
                      มหาวิทยาลัยบูรพา
                    </div>
                  </div>
                  <div class="row px-md ml-md pt-sm" style="gap: 8px">
                    <div style="flex: 1" class="pl-md ml-md d-flex wrap">
                        <div class="row">
                            <span>จำนวนเงิน</span>
                            <span style="max-width: 150px; width: 150px;" 
                                  class="<%= body?.fundSumRequest ? 'text-dot text-center' : 'text-dot-no-value' %>">
                                <%= toThaiNumber(Number(body?.fundSumRequest).toLocaleString('en-US',{
                                    minimumFractionDigits: body?.fundSumRequest % 1 === 0 ? 0 : 2,
                                    maximumFractionDigits: 2
                                })) %>
                            </span>
                            <span>บาท</span>
                            <span>(</span>
                            <span style="max-width: 200px; width: 200px;"
                                  class="<%= body?.fundSumRequest ? 'text-dot text-center' : 'text-dot-no-value' %>">
                                <%= bahttext(Number(body?.fundSumRequest)) %>
                            </span>
                            <span>)</span>
                            <span class="line-break <%= (bahttext(Number(body?.fundSumRequest)).length > 40) ? 'dynamic-line-break' : '' %>">
                              ไว้ถูกต้องแล้ว/ครบถ้วนแล้ว
                          </span>
                        </div>
                    </div>
                </div>
                
                </div>
              </div>
              <div class="row px-md py-md"
                style="gap: 8px; align-items: flex-end">
                <div class="col"></div>
                <div class="col row justify-center">
                  <div class="col-sign">
                    ลงชื่อ <div class="text-dot-no-value"
                      style="max-width: 200px;"></div>ผู้รับเงิน
                  </div>
                  <div class="col-sign py-sm text-center">
                    ( <div class="text-dot" style="max-width: 220px;"> </div> )
                  </div>
                </div>
